# Address of the deployed CrowdfundingPlatform contract
NEXT_PUBLIC_CONTRACT_ADDRESS=your_deployed_contract_address

# Pinata JWT Token for IPFS uploads (Optional: falls back to mock uploader if left blank)
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token

# Pinata IPFS Gateway URL
NEXT_PUBLIC_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# RainbowKit/WalletConnect Project ID (Optional: falls back to default ID if left blank)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id
